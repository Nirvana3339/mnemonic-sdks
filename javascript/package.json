{
  "name": "@mnemonicai.official/sdk-js",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Persistent cognitive infrastructure for AI agents — memory, procedural learning, and cross-agent intelligence that compounds over time.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "keywords": [
    "ai-agents", "agent-memory", "persistent-memory", "cognitive-infrastructure",
    "procedural-learning", "llm", "openai", "anthropic", "claude", "langchain",
    "autogen", "multi-agent", "agent-framework", "vector-search", "rag",
    "operational-intelligence", "workflow-evolution", "cross-agent", "memory-layer",
    "typescript", "javascript"
  ],
  "author": "Nishant Vanawala <hello@mnemonic.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nirvana3339/mnemonic-sdks.git",
    "directory": "javascript"
  },
  "homepage": "https://mnemonic.dev",
  "bugs": {
    "url": "https://github.com/Nirvana3339/mnemonic-sdks/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
