{
  "name": "@mnemonic-ai/mcp",
  "version": "0.1.0",
  "description": "Mnemonic MCP server — persistent memory tools for Claude Desktop, Cursor, and any MCP-compatible host",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mnemonic-mcp": "dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "dev": "tsup src/index.ts --format cjs --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mnemonic", "mcp", "model-context-protocol", "ai-agents",
    "agent-memory", "claude", "cursor", "persistent-memory"
  ],
  "author": "Mnemonic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nirvana3339/mnemonic-sdks.git",
    "directory": "mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
